# BallDontLie API key (optional — rosters/games; game logs use ESPN/NBA fallback)
BALLDONTLIE_API_KEY=

# Upstash Redis (required on Vercel — from Storage → Upstash Redis integration)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Legacy Vercel KV names still work if present
KV_REST_API_URL=
KV_REST_API_TOKEN=

# NBA season start year for game logs (e.g. 2025 = 2025-26 season)
NBA_SEASON=2025
